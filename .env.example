# --- Anthropic (LLM provider for research + grading) ---
ANTHROPIC_API_KEY=

# --- CAP / CROO network ---
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws

# Each agent authenticates with its own SDK-Key, issued from the CROO Dashboard
# when the agent + its service are registered. The SDK never touches a private
# key directly - signing happens server-side, and each agent's on-chain wallet
# (visible in the Dashboard) must be funded with USDC before it can pay for
# anything. Never commit real values.
ORCHESTRATOR_SDK_KEY=
SOURCE_FINDER_SDK_KEY=
CLAIM_GRADER_SDK_KEY=

# Not a real network participant - just an identity for testing and for the
# demo recording (see packages/orchestrator/src/simulate-buyer.ts). Needs a
# funded wallet in live mode but no registered service of its own.
DEMO_BUYER_SDK_KEY=
DEMO_BUYER_SERVICE_ID=

# --- CAP service IDs ---
# Price is a property of a registered service, not something negotiated
# per-request - set these once each service is created in the Dashboard.
# Each agent here owns exactly one service, so its service ID is also its
# address in the network.
ORCHESTRATOR_SERVICE_ID=diligence-lead-v1
SOURCE_FINDER_SERVICE_ID=source-finder-v1
CLAIM_GRADER_SERVICE_ID=claim-grader-v1

# Prices, for reference (the authoritative price lives on the service
# registration in the Dashboard - these are what we expect it to be, used
# only by the simulated transport's service directory).
ORCHESTRATOR_PRICE_USDC=4.00
SOURCE_FINDER_PRICE_USDC=0.50
CLAIM_GRADER_PRICE_USDC=0.35

# --- Runtime mode ---
# live: real CAP SDK calls, real Base-mainnet USDC settlement.
# simulated: a faithful in-process reproduction of the same order-lifecycle
#            state machine (negotiate -> accept -> pay -> deliver -> clear),
#            backed by a shared local database instead of the real network.
#            Every agent's business logic is identical in both modes - see
#            packages/core/src/capClient.ts.
CAP_MODE=simulated

# --- Persistence ---
DILIGENCE_DB_PATH=./data/diligence.sqlite
CAP_SIM_DB_PATH=./data/cap-sim.sqlite

# --- Dashboard ---
DASHBOARD_PORT=4400
